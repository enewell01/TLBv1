---
const points = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>`,
    title: 'Licensed & Insured',
    description: 'Every job is performed by a licensed electrician. You get peace of mind knowing your electrical work meets all safety codes.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>`,
    title: 'Prompt & Reliable',
    description: 'We show up on time and get the work done. No runaround, no surprises — just straightforward service you can depend on.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>`,
    title: 'Locally Based',
    description: 'We\'re a Moncton business serving Moncton people. You\'re not a ticket number — you\'re a neighbour.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.5 2C6.81 2 3 5.81 3 10.5S6.81 19 11.5 19h.5v3c4.86-2.34 8-7 8-11.5C20 5.81 16.19 2 11.5 2zm1 14.5h-2v-2h2v2zm0-4h-2c0-3.25 3-3 3-5 0-1.1-.9-2-2-2s-2 .9-2 2h-2c0-2.21 1.79-4 4-4s4 1.79 4 4c0 2.5-3 2.75-3 5z"/></svg>`,
    title: 'Transparent Pricing',
    description: 'Free quotes with no hidden fees. We explain the work, give you a clear price, and stick to it.',
  },
];
---

<section class="why-us" id="why-us">
  <div class="container">
    <div class="why-us-layout">
      <div class="why-us-left">
        <p class="section-label">Why TLB Electric</p>
        <h2 class="section-title" style="color: var(--white);">Built on Trust.<br />Backed by Results.</h2>
        <p class="section-subtitle" style="color: rgba(255,255,255,0.7);">
          When you hire TLB Electric, you get a team that takes pride in clean, safe, lasting work — and treats your home or business like their own.
        </p>
        <a href="#contact" class="btn btn-primary" style="margin-top: 2rem;">Request Your Free Quote</a>
      </div>
      <div class="why-us-right">
        {points.map(point => (
          <div class="point-card">
            <div class="point-icon" set:html={point.icon} />
            <div class="point-body">
              <h3 class="point-title">{point.title}</h3>
              <p class="point-description">{point.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .why-us {
    padding: 6rem 0;
    background: var(--charcoal);
    position: relative;
    overflow: hidden;
  }

  .why-us::before {
    content: '';
    position: absolute;
    top: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(213, 44, 60, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .why-us-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .why-us-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .point-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 1.5rem;
    transition: background 0.2s, border-color 0.2s;
  }

  .point-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(213, 44, 60, 0.4);
  }

  .point-icon {
    width: 36px;
    height: 36px;
    color: var(--red);
    margin-bottom: 1rem;
  }

  .point-icon svg {
    width: 100%;
    height: 100%;
  }

  .point-title {
    font-size: 0.975rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .point-description {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .why-us-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 560px) {
    .why-us-right {
      grid-template-columns: 1fr;
    }
  }
</style>
