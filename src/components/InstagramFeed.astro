---
// To activate this feed:
// 1. Go to https://behold.so and sign up for free
// 2. Connect TLB Electric's Instagram account
// 3. Create a new feed — copy the Feed ID (looks like: abc123xyz)
// 4. Replace YOUR_FEED_ID_HERE below with that Feed ID
// The feed will automatically stay in sync with new Instagram posts & videos.

const BEHOLD_FEED_ID = 'YOUR_FEED_ID_HERE';
const isConfigured = BEHOLD_FEED_ID !== 'YOUR_FEED_ID_HERE';
---

<section class="instagram" id="instagram">
  <div class="container">
    <div class="instagram-header">
      <div>
        <p class="section-label">Follow Our Work</p>
        <h2 class="section-title">See Us On Instagram</h2>
        <p class="section-subtitle">Follow along as we share real jobs, before &amp; afters, and updates from the Greater Moncton area.</p>
      </div>
      <a
        href="https://www.instagram.com/tlbelectric"
        target="_blank"
        rel="noopener noreferrer"
        class="instagram-follow-btn"
        aria-label="Follow TLB Electric on Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @tlbelectric
      </a>
    </div>

    {isConfigured ? (
      <div class="behold-feed">
        <behold-widget feed-id={BEHOLD_FEED_ID}></behold-widget>
      </div>
    ) : (
      <div class="feed-placeholder">
        <div class="placeholder-grid">
          {Array.from({ length: 6 }).map((_, i) => (
            <div class="placeholder-cell">
              <div class="placeholder-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                <span>Instagram Post</span>
              </div>
            </div>
          ))}
        </div>
        <p class="placeholder-note">
          Instagram feed will display here once connected via <a href="https://behold.so" target="_blank" rel="noopener noreferrer">Behold.so</a>
        </p>
      </div>
    )}
  </div>
</section>

{isConfigured && (
  <script src="https://w.behold.so/widget.js" type="module"></script>
)}

<style>
  .instagram {
    padding: 6rem 0;
    background: var(--white);
  }

  .instagram-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .instagram-follow-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);
    color: var(--white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.875rem;
    padding: 0.7rem 1.4rem;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .instagram-follow-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .behold-feed {
    width: 100%;
  }

  /* Placeholder grid shown until Behold is configured */
  .placeholder-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 4px;
    border-radius: 8px;
    overflow: hidden;
  }

  .placeholder-cell {
    aspect-ratio: 1;
    background: var(--off-white);
    border: 1px solid var(--gray);
  }

  .placeholder-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: #ccc;
    font-size: 0.7rem;
    font-family: var(--font-heading);
    text-align: center;
    padding: 0.5rem;
  }

  .placeholder-note {
    text-align: center;
    margin-top: 1.25rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-family: var(--font-heading);
  }

  .placeholder-note a {
    color: var(--red);
    font-weight: 600;
    text-decoration: underline;
  }

  @media (max-width: 700px) {
    .instagram-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .placeholder-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
