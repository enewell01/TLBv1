---
---

<section class="quote-cta">
  <div class="container quote-cta-inner">
    <div class="quote-cta-text">
      <h2 class="quote-cta-title">Ready to Get Started?</h2>
      <p class="quote-cta-subtitle">Get a free, no-obligation quote from a licensed Moncton electrician today.</p>
    </div>
    <div class="quote-cta-actions">
      <a href="#contact" class="btn btn-primary cta-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
        Request a Free Quote
      </a>
      <a href="tel:5068755337" class="btn btn-outline cta-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        Call Us Now
      </a>
    </div>
  </div>
</section>

<style>
  .quote-cta {
    background: var(--red);
    padding: 4rem 0;
  }

  .quote-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .quote-cta-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .quote-cta-subtitle {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1rem;
  }

  .quote-cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .cta-btn {
    padding: 0.875rem 1.75rem;
  }

  .quote-cta .btn-primary {
    background: var(--charcoal);
    border-color: var(--charcoal);
  }

  .quote-cta .btn-primary:hover {
    background: #1a181a;
    border-color: #1a181a;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 700px) {
    .quote-cta-inner {
      flex-direction: column;
      text-align: center;
    }

    .quote-cta-actions {
      justify-content: center;
      width: 100%;
    }

    .cta-btn {
      flex: 1;
      justify-content: center;
    }
  }
</style>
